{
  "id": "d5.2",
  "title": "Showing links between decisions",
  "category": "Visualization",
  "phase": "Design",
  "type": "technical",
  "version": "1.0",
  "question": "How should the way one decision connects to another be shown?",
  "status": "decided",
  "supersedes": [
    "d5.1"
  ],
  "date": "2026-06-20T16:14:05",
  "rationale": "The cascade job — seeing what revisiting a decision threatens — needs the full downstream chain, not just one hop. Extended 'Affects' to walk transitively (downstream only), kept it inline with no separate map.",
  "options": [
    {
      "id": "o5a",
      "label": "Inline links + full downstream impact (flat list)",
      "chosen": true,
      "tradeoffs": [
        {
          "criterion": "fits review goal",
          "sentiment": "+",
          "note": "jump between linked decisions without leaving the list"
        },
        {
          "criterion": "answers the cascade job",
          "sentiment": "+",
          "note": "'Affects' walks several hops, so you see everything a decision threatens"
        },
        {
          "criterion": "whole-picture view",
          "sentiment": "~",
          "note": "deep chains can get long; mitigated by downstream-only and collapsing"
        }
      ]
    },
    {
      "id": "o5b",
      "label": "Optional connections map",
      "chosen": false,
      "tradeoffs": [
        {
          "criterion": "whole-picture view",
          "sentiment": "+",
          "note": "see every connection at once"
        },
        {
          "criterion": "build effort",
          "sentiment": "~",
          "note": "a second map view to build"
        }
      ]
    },
    {
      "id": "o5c",
      "label": "Both",
      "chosen": false,
      "tradeoffs": [
        {
          "criterion": "fits review goal",
          "sentiment": "+",
          "note": "inline links keep reviewing front and center"
        },
        {
          "criterion": "whole-picture view",
          "sentiment": "+",
          "note": "a map for the full web"
        },
        {
          "criterion": "build effort",
          "sentiment": "-",
          "note": "two things to build"
        }
      ]
    },
    {
      "id": "o5d",
      "label": "Just save the links, show them later",
      "chosen": false,
      "tradeoffs": [
        {
          "criterion": "build effort",
          "sentiment": "+",
          "note": "display can come later"
        },
        {
          "criterion": "whole-picture view",
          "sentiment": "-",
          "note": "nothing visible yet"
        }
      ]
    }
  ]
}
