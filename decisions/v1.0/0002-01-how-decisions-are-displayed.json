{
  "id": "d2.1",
  "title": "How decisions are displayed",
  "category": "Visualization",
  "phase": "Design",
  "type": "technical",
  "version": "1.0",
  "question": "How should the saved decisions be shown on screen?",
  "status": "decided",
  "supersedes": [
    "d2"
  ],
  "rationale": "The web-of-nodes and 3D views were good for analysis and looked impressive, but got away from the goal of reviewing past decisions. Switched to a grouped review list.",
  "options": [
    {
      "id": "o2a",
      "label": "Connected web of nodes (interactive graph)",
      "chosen": false,
      "tradeoffs": [
        {
          "criterion": "shows connections",
          "sentiment": "+",
          "note": "shared tradeoffs visibly link decisions"
        },
        {
          "criterion": "build effort",
          "sentiment": "~",
          "note": "one script to build the page"
        }
      ]
    },
    {
      "id": "o2b",
      "label": "Simple branching tree (Mermaid)",
      "chosen": false,
      "tradeoffs": [
        {
          "criterion": "shows connections",
          "sentiment": "-",
          "note": "strict tree; each item can have only one parent"
        },
        {
          "criterion": "build effort",
          "sentiment": "+",
          "note": "very easy to produce"
        }
      ]
    },
    {
      "id": "o2c",
      "label": "Grouped review list",
      "chosen": true,
      "tradeoffs": [
        {
          "criterion": "shows connections",
          "sentiment": "-",
          "note": "doesn't picture how decisions link together"
        },
        {
          "criterion": "build effort",
          "sentiment": "+",
          "note": "plain web page, no outside software, works offline"
        },
        {
          "criterion": "fits review goal",
          "sentiment": "~",
          "note": "browse by topic, but shows every decision in full at once"
        }
      ]
    },
    {
      "id": "o2d",
      "label": "List plus detail panel (one decision at a time)",
      "chosen": false,
      "tradeoffs": [
        {
          "criterion": "fits review goal",
          "sentiment": "+",
          "note": "left: short list; right: full text of the one you pick"
        },
        {
          "criterion": "build effort",
          "sentiment": "+",
          "note": "plain offline web page, no outside software"
        },
        {
          "criterion": "looks designed",
          "sentiment": "-",
          "note": "plain two-pane; read as dated, too close to the original"
        }
      ]
    },
    {
      "id": "o2e",
      "label": "Card grid + focused pop-up (apple.com-style)",
      "chosen": false,
      "tradeoffs": [
        {
          "criterion": "fits review goal",
          "sentiment": "+",
          "note": "scan cards by stage, then open one decision in a focused pop-up"
        },
        {
          "criterion": "looks designed",
          "sentiment": "+",
          "note": "big type, whitespace, cards in a grid — feels like a real product page"
        },
        {
          "criterion": "build effort",
          "sentiment": "+",
          "note": "still a plain offline page, opens by double-clicking"
        }
      ]
    }
  ]
}
